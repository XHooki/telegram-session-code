# Telegram client API credentials from https://my.telegram.org
TG_API_ID=123456
TG_API_HASH=replace_with_your_api_hash

# Fernet key. Generate with: python scripts/make_fernet_key.py
SESSION_SECRET_KEY=replace_with_generated_fernet_key

# Bot whitelist. Use exact usernames, comma separated, without or with @.
TG_BOT_USERNAMES=BotFather

# Folder name that will be created/updated in every employee account.
TG_FOLDER_TITLE=企业机器人

# SQLite database path.
DB_PATH=data/app.db

# Optional admin token for simple admin APIs. Change in production.
ADMIN_TOKEN=change_me
